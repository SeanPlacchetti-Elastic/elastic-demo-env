# Project namespace
COMPOSE_PROJECT_NAME=elastic-ccs-demo

# Password for the 'elastic' superuser on both clusters (at least 6 characters)
ELASTIC_PASSWORD=changeme

# Password for the 'kibana_system' service account on cluster-west
KIBANA_PASSWORD=changeme

# Password for the 'kibana_system' service account on cluster-east (different from west)
EAST_KIBANA_PASSWORD=east-changeme

# Version of Elastic products
# https://www.elastic.co/downloads/past-releases#elasticsearch
STACK_VERSION=8.19.14

# West cluster name — local/querying cluster, holds air quality and app event data
WEST_CLUSTER_NAME=cluster-west

# East cluster name — remote cluster, holds web access, DB query, and API metrics data
EAST_CLUSTER_NAME=cluster-east

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=trial

# Port to expose west cluster Elasticsearch HTTP API to the host
WEST_ES_PORT=9200

# Port to expose east cluster Elasticsearch HTTP API to the host
EAST_ES_PORT=9201

# Port to expose west Kibana to the host
KIBANA_PORT=5601

# Port to expose east Kibana to the host
EAST_KIBANA_PORT=5602

# Port to expose west APM Server to the host
APMSERVER_PORT=8200

# Port to expose east APM Server to the host
EAST_APMSERVER_PORT=8201

# Port to expose west webapp to the host
WEBAPP_PORT=8000

# Port to expose east webapp (development) to the host
EAST_WEBAPP_PORT=8001

# Port to expose production gateway to the host
PROD_WEBAPP_PORT=8002

# Port to expose search cluster Elasticsearch to the host
SEARCH_ES_PORT=9202

# Search cluster name
SEARCH_CLUSTER_NAME=search-cluster

# Search cluster memory limit (single node, 1.5 GB)
SEARCH_ES_MEM_LIMIT=1610612736

# Port to expose search Kibana to the host
SEARCH_KIBANA_PORT=5603

# Password for the 'kibana_system' service account on the search cluster
SEARCH_KIBANA_PASSWORD=search-changeme

# Search Kibana memory limit (1 GB)
SEARCH_KB_MEM_LIMIT=1073741824

# APM Secret Token — for POC environments only
ELASTIC_APM_SECRET_TOKEN=supersecrettoken

# Memory limits in bytes
# West cluster nodes (3 nodes × 3 GB each)
ES_MEM_LIMIT=3073741824
# East cluster nodes (3 nodes × 2 GB each)
EAST_ES_MEM_LIMIT=2147483648
# West Kibana (1 GB)
KB_MEM_LIMIT=1073741824
# East Kibana (1 GB)
EAST_KB_MEM_LIMIT=1073741824

# Encryption key — sample value for POC environments only
ENCRYPTION_KEY=c34d38b3a14956121ff2170e5030b471551370178f43e5626eec58b04a30fae2
