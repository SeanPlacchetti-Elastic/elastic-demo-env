# syntax=docker/dockerfile:1
# ── Build stage ───────────────────────────────────────────────────────────────
FROM golang:1.22-alpine AS build
WORKDIR /app
COPY go.mod main.go ./
# go mod tidy resolves transitive deps and writes go.sum in one step
RUN go mod tidy && CGO_ENABLED=0 GOOS=linux go build -o server .

# ── Runtime stage ─────────────────────────────────────────────────────────────
FROM alpine:3.19
WORKDIR /app
COPY --from=build /app/server .
CMD ["/app/server"]
