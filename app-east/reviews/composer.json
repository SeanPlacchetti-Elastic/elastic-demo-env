    "slim/psr7": "^1.6",
    "monolog/monolog": "^3.0",
    "php-di/php-di": "^7.0",
    "ext-mongodb": "*",
    "mongodb/mongodb": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
